new_dt = dt + timedelta(days=5, hours=3)
print(new_dt)


from datetime import datetime

dt1 = datetime(2025, 2, 17, 10, 30, 57)
dt2 = datetime(2025, 2, 20, 15, 0, 0)

diff = dt2 - dt1
print(diff)
print(diff.total_seconds())










































