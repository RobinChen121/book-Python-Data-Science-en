def plus(x, *a):
    print("x is %d" % x)
    for var in a:
        x += var
    print("final x is %d" % x)


plus(3, 4, 5)  # *a is [4, 5]
plus(3, 4, 5, 6)  # *a is [4, 5, 6]





def minus(x1, **a):
    sum = 0
    for key in a:
        sum += a[key]
        return x1 - sum


print(minus(10, x2=3, x3=5))



























































